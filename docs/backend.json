
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user preferences and settings.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "preferences": {
          "type": "object",
          "properties": {
            "language": { "type": "string", "enum": ["en", "ar", "fr", "es", "de"] },
            "theme": { "type": "string", "enum": ["light", "dark", "system"] },
            "autoSpeak": { "type": "boolean" },
            "voiceName": { "type": "string" }
          }
        }
      }
    },
    "Chat": {
      "title": "Chat Session",
      "description": "A metadata record for a conversation session.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastMessage": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["userId", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "An individual message within a chat.",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "content", "timestamp"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile and settings."
    },
    "/users/{userId}/chats/{chatId}": {
      "schema": "Chat",
      "description": "List of chat sessions for a user."
    },
    "/users/{userId}/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Individual messages in a specific chat."
    }
  }
}
